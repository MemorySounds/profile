---
pagination:
  data: projects
  size: 1
  alias: project
  addAllPagesToCollections: false
permalink: /projects/{{ project.slug }}/
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <script>
      (function () {
        try {
          if (window.sessionStorage.getItem("tileTransitionPending") === "1") {
            document.documentElement.classList.add("tile-transition-pending");
          }
        } catch (_) {
          // No-op: fallback to normal render path.
        }
      })();
    </script>
    <title>{{ project.title }} - Robert Sahakyan</title>
    <link rel="stylesheet" href="/styles/main.css" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link
      href="https://fonts.googleapis.com/css?family=Sora:400,700&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <!-- Static page-transition cover (see index.html). Paints covered on the
         first frame when html.tile-transition-pending is set — no blank flash. -->
    <div id="tile-transition-overlay" aria-hidden="true">
      <div class="tile-transition-tile"></div>
      <div class="tile-transition-tile"></div>
      <div class="tile-transition-tile"></div>
    </div>

    <div class="project-page">
      <header class="project-page-header">
        <a href="/?from=project#selected-works" class="project-page-back" data-page-transition>&larr; Back to Selected Works</a>
      </header>

      <main class="project-page-main">
        <div class="project-page-top">
          <p class="modal-date">{{ project.date }}</p>
          <h1 class="modal-title">{{ project.title }}</h1>
          <a
            href="{{ project.website }}"
            class="official-link link"
            target="_blank"
            rel="noopener noreferrer"
          >
            Company Website
          </a>
        </div>

        {% for section in project.sections %}
          <div class="modal-section">
            <div class="section-header">
              <span class="section-title">{{ section.title }}</span>
              <span class="section-line"></span>
            </div>
            {% if section.title == "TECH" and section.content is iterable and section.content is not string %}
              <div class="modal-section-content tech-list">
                {% for tech in section.content %}
                  <span>{{ tech }}</span>
                {% endfor %}
              </div>
            {% else %}
              <div class="modal-section-content">{{ section.content | safe }}</div>
            {% endif %}
          </div>
        {% endfor %}

        <nav class="project-page-nav">
          {% if pagination.href.previous %}
            <a href="{{ pagination.href.previous }}" class="project-page-prev-btn" data-page-transition>&larr; Previous</a>
          {% endif %}
          {% if pagination.href.next %}
            <a href="{{ pagination.href.next }}" class="project-page-next-btn" data-page-transition>Next &rarr;</a>
          {% endif %}
        </nav>
      </main>
    </div>
    <script src="https://cdn.jsdelivr.net/npm/gsap@3/dist/gsap.min.js"></script>
    <script src="/scripts/page-transition.js"></script>
  </body>
</html>
